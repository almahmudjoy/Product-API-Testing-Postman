    {
      "name": "End-to-End Workflow Tests",
      "item": [
        {
          "name": "TC03_POST_Create_Product_Valid_Data",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {\r",
                  "    pm.response.to.have.status(201);\r",
                  "});\r",
                  "\r",
                  "let jsonData = pm.response.json();\r",
                  "\r",
                  "pm.test(\"Generated ID exists\", function () {\r",
                  "    pm.expect(jsonData.id).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Created product fields are correct\", function () {\r",
                  "    pm.expect(jsonData.name).to.eql(pm.collectionVariables.get(\"dynamicProductName\"));\r",
                  "    pm.expect(jsonData.price).to.eql(90);\r",
                  "    pm.expect(jsonData.category).to.eql(\"Grocery\");\r",
                  "});\r",
                  "\r",
                  "pm.collectionVariables.set(\"productId\", jsonData.id);\r",
                  "pm.collectionVariables.set(\"productName\", jsonData.name);\r",
                  "\r",
                  "const schema = {\r",
                  "    type: \"object\",\r",
                  "    required: [\"id\", \"name\", \"price\", \"category\"],\r",
                  "    properties: {\r",
                  "        id: { type: \"string\" },\r",
                  "        name: { type: \"string\" },\r",
                  "        price: { type: \"number\" },\r",
                  "        category: { type: \"string\" }\r",
                  "    }\r",
                  "};\r",
                  "\r",
                  "pm.test(\"Product schema is valid\", function () {\r",
                  "    pm.response.to.have.jsonSchema(schema);\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const randomNum = Math.floor(Math.random() * 100000);\r",
                  "pm.collectionVariables.set(\"dynamicProductName\", \"Sugar_\" + randomNum);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"name\": \"{{dynamicProductName}}\",\r\n  \"price\": 90,\r\n  \"category\": \"Grocery\"\r\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseURL}}/products",
              "host": [
                "{{baseURL}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
